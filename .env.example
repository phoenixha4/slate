APP_ENV=development
LOG_LEVEL=debug
LOG_FORMAT=pretty

PORT=8080
HOST_PORT=8080

POSTGRES_DB=todo
POSTGRES_USER=todo
POSTGRES_PASSWORD=todo
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgres://todo:todo@db:5432/todo?sslmode=disable

CORS_ALLOWED_ORIGINS=*

READ_TIMEOUT=15s
WRITE_TIMEOUT=30s
IDLE_TIMEOUT=60s
SHUTDOWN_TIMEOUT=10s
READINESS_TIMEOUT=2s
